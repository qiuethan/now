# Copy this file to `.env` and fill in your keys for local `npm run generate`.
# `.env` is gitignored. In GitHub Actions these come from repo secrets instead.

GH_PAT=             # PAT with read access to private repos (for include_private)
OPENAI_API_KEY=     # AI "this week" summary + anonymized private-repo blurbs
WAKATIME_API_KEY=   # https://wakatime.com/api-key — coding-time section
# NOW_LLM_MODEL=    # optional model override (default: gpt-5-mini)
